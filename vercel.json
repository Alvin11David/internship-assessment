{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install && pip install -r requirements.txt",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "env": [
    {
      "key": "SUNBIRD_API_TOKEN",
      "description": "Your Sunbird AI API token (get from https://app.sunbird.ai/)"
    }
  ]
}
